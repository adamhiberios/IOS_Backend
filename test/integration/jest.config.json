{
  "rootDir": "../..",
  "testEnvironment": "node",
  "testMatch": ["<rootDir>/test/integration/**/*.e2e-spec.ts"],
  "moduleFileExtensions": ["js", "json", "ts"],
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "<rootDir>/tsconfig.json" }]
  },
  "globalSetup": "<rootDir>/test/integration/setup.ts",
  "globalTeardown": "<rootDir>/test/integration/teardown.ts",
  "setupFiles": ["<rootDir>/test/integration/setup-env.ts"],
  "testTimeout": 30000,
  "maxWorkers": 1,
  "verbose": true,
  "forceExit": true,
  "collectCoverage": false,
  "reporters": [
  "default",
  ["jest-junit", { "outputDirectory": "./coverage", "outputName": "integration-junit.xml" }],
  ["jest-html-reporter", { "outputPath": "./coverage/integration-report.html", "pageTitle": "IOS LMS Integration" }]
]
}
