# syntax=docker/dockerfile:1.6
# =============================================================================
# IOS LMS API — Development Dockerfile
#
# Runs `nest start --watch` for hot reload. Source is mounted from the host
# via docker-compose, so file changes trigger automatic recompilation.
# =============================================================================

FROM node:20.18-alpine

WORKDIR /app

# Build tools needed for bcrypt + other native modules
RUN apk add --no-cache python3 make g++ wget tini \
  && ln -sf python3 /usr/bin/python

ENV NODE_ENV=development \
    PORT=3000

# Install dependencies first to maximise layer cache hits
COPY package.json package-lock.json ./
RUN npm ci --no-audit --no-fund

# Source is mounted at runtime via docker-compose volume; we don't COPY it here

EXPOSE 3000

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["npm", "run", "start:dev"]
