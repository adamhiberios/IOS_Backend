# ── super_admin bootstrap (SeederService) ──────────────────────────────────
# On startup, SeederService creates a super_admin row if none exists.
#
# Behavior by NODE_ENV:
#   - development / test: env vars below are OPTIONAL. If unset, falls back
#     to dev defaults (admin@ios.local / DevAdmin@123!). LOUD warning logged.
#   - staging: BOOTSTRAP_SUPER_ADMIN_EMAIL + _PASSWORD + _FIRST_NAME +
#     _LAST_NAME are REQUIRED. App refuses to start without them.
#   - production: ADDITIONALLY requires BOOTSTRAP_SUPER_ADMIN=true as an
#     explicit opt-in. Without that flag the seeder is a no-op.
#
# After the first successful bootstrap, the seeder becomes a no-op forever
# (an existing super_admin causes it to skip). The protect_super_admin_role
# DB trigger blocks any attempt to mutate or delete the row.
BOOTSTRAP_SUPER_ADMIN=false
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@ios.local
BOOTSTRAP_SUPER_ADMIN_PASSWORD=DevAdmin@123!
BOOTSTRAP_SUPER_ADMIN_FIRST_NAME=IOS
BOOTSTRAP_SUPER_ADMIN_LAST_NAME=Admin
