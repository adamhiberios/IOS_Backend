# =============================================================================
# Docker Compose Environment — IOS LMS
#
# Copy this file to `.env` in the project root, then run `docker compose up`.
# The defaults work out of the box for local development.
# =============================================================================

# ─── Service ports (host-side) ──────────────────────────────────────────────
PORT=3000
WS_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379
ADMINER_PORT=8080

# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=ios
POSTGRES_PASSWORD=iospass
POSTGRES_DB=ios_lms

# ─── JWT — change these for production ──────────────────────────────────────
JWT_SECRET=development-only-jwt-access-secret-min-64-chars-replace-in-production
JWT_REFRESH_SECRET=development-only-jwt-refresh-secret-different-from-access-secret-here
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ─── App ────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:4000
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,tr,fr,es,ar,de

# ─── External services — mocks for dev, real keys in prod ──────────────────
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_mock
SENDGRID_API_KEY=SG.mock
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=ios-lms-assets
DO_SPACES_KEY=mock_key
DO_SPACES_SECRET=mock_secret
